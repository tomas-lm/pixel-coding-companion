{
  "name": "pixel-coding-companion",
  "productName": "Pixel Companion",
  "version": "1.0.0",
  "description": "A pixel companion for coordinating local coding agent sessions.",
  "main": "./out/main/index.js",
  "author": "Tomas Muniz",
  "license": "MIT",
  "homepage": "https://github.com/tomas-lm/pixel-coding-companion",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomas-lm/pixel-coding-companion.git"
  },
  "bin": {
    "pixel": "./scripts/pixel.mjs"
  },
  "bugs": {
    "url": "https://github.com/tomas-lm/pixel-coding-companion/issues"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "check:ci": "bash scripts/check-ci.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build:native:dictation": "bash scripts/build-dictation-helper.sh",
    "start": "electron-vite preview",
    "dev": "npm run build:native:dictation && electron-vite dev",
    "dev:isolated": "npm run build:native:dictation && PIXEL_COMPANION_APP_NAME='Pixel Companion Dev' PIXEL_COMPANION_APP_ID='dev.tomasmuniz.pixel-coding-companion.dev' PIXEL_COMPANION_USER_DATA_DIR='pixel-coding-companion-dev' PIXEL_COMPANION_DATA_DIR=\"$HOME/Library/Application Support/pixel-coding-companion-dev\" electron-vite dev",
    "stop:dev-packaged": "node scripts/dev-packaged-app.mjs stop",
    "build:dev-unpack": "npm run stop:dev-packaged && npm run build:native:dictation && VITE_PIXEL_COMPANION_DEV_STORE_CONTROLS=true npm run build && electron-builder --dir -c.productName='Pixel Companion Dev' -c.appId='dev.tomasmuniz.pixel-coding-companion.dev' -c.directories.output=dist-dev",
    "open:dev-packaged": "node scripts/dev-packaged-app.mjs open",
    "dev:packaged": "npm run build:dev-unpack && npm run open:dev-packaged",
    "open:stable": "open -n 'dist/mac-arm64/Pixel Companion.app'",
    "mcp": "node scripts/pixel-companion-mcp.mjs",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build:native:dictation && npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build:native:dictation && electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@lezer/markdown": "^1.6.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^29.1.1",
    "node-gyp": "^12.3.0",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ]
  }
}
