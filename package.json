{
  "name": "pixel-coding-companion",
  "productName": "Pixel Companion",
  "version": "1.0.0",
  "description": "A pixel companion for coordinating local coding agent sessions.",
  "main": "./out/main/index.js",
  "author": "Tomas Muniz",
  "license": "MIT",
  "homepage": "https://github.com/tomas-lm/pixel-coding-companion",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomas-lm/pixel-coding-companion.git"
  },
  "bin": {
    "pixel": "./scripts/pixel.mjs"
  },
  "bugs": {
    "url": "https://github.com/tomas-lm/pixel-coding-companion/issues"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "check:ci": "bash scripts/check-ci.sh",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "dev:isolated": "PIXEL_COMPANION_APP_NAME='Pixel Companion Dev' PIXEL_COMPANION_APP_ID='dev.tomasmuniz.pixel-coding-companion.dev' PIXEL_COMPANION_USER_DATA_DIR='pixel-coding-companion-dev' PIXEL_COMPANION_DATA_DIR=\"$HOME/Library/Application Support/pixel-coding-companion-dev\" electron-vite dev",
    "open:stable": "open -n 'dist/mac-arm64/Pixel Companion.app'",
    "mcp": "node scripts/pixel-companion-mcp.mjs",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ]
  }
}
